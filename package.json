{
  "name": "opennori",
  "version": "0.1.9",
  "description": "OpenNori: human-centered Nori Contracts and evidence records for coding agents.",
  "type": "module",
  "bin": {
    "opennori": "bin/opennori.js"
  },
  "files": [
    ".agents/plugins/",
    ".opennori/protocol.md",
    "bin/opennori.js",
    "dashboard/",
    "dist/",
    "plugins/opennori/",
    "src/",
    "schemas/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json && npm run typecheck:dashboard && npm run build:dashboard",
    "build:dashboard": "vite build --config vite.dashboard.config.ts",
    "typecheck": "tsc --noEmit && npm run typecheck:dashboard",
    "typecheck:dashboard": "tsc -p tsconfig.dashboard.json --noEmit",
    "format": "biome format --write package.json tsconfig.json tsconfig.build.json tsconfig.dashboard.json vitest.config.ts vite.dashboard.config.ts src/dashboard",
    "lint": "biome lint .",
    "test": "npm run build && vitest run",
    "test:node": "node --test",
    "check": "biome lint . && tsc --noEmit && npm run build && vitest run && node ./bin/opennori.js doctor --json"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@hono/node-server": "^2.0.4",
    "ajv": "^8.17.1",
    "citty": "^0.2.2",
    "hono": "^4.12.25",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agent",
    "workflow",
    "acceptance",
    "codex",
    "claude"
  ],
  "author": "okbexx <okbexx@gmail.com>",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=20"
  }
}
