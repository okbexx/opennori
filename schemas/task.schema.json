{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opennori.dev/schemas/task.schema.json",
  "title": "OpenNori Task",
  "$defs": {
    "taskId": {
      "type": "string",
      "maxLength": 91,
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]+)?Z$"
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "description", "status", "implementation_revision", "priority", "creator", "delivery_required", "created_at", "updated_at"],
  "properties": {
    "schema_version": { "const": "opennori/task-v2" },
    "id": { "$ref": "#/$defs/taskId" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "status": { "enum": ["planning", "in_progress", "review", "completed"] },
    "implementation_revision": { "type": "integer", "minimum": 1 },
    "priority": { "enum": ["P0", "P1", "P2", "P3"] },
    "creator": { "type": "string", "minLength": 1 },
    "delivery_required": { "type": "boolean" },
    "package": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$", "maxLength": 80 }
      ]
    },
    "blocker": {
      "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
    },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "updated_at": { "$ref": "#/$defs/timestamp" },
    "completed_at": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/timestamp" }]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "completed" } }, "required": ["status"] },
      "then": {
        "required": ["completed_at"],
        "properties": {
          "completed_at": { "$ref": "#/$defs/timestamp" },
          "blocker": { "const": null }
        }
      },
      "else": { "properties": { "completed_at": { "type": "null" } } }
    }
  ]
}
