{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opennori.dev/schemas/contract.schema.json",
  "title": "Nori Contract",
  "$defs": {
    "taskId": {
      "type": "string",
      "maxLength": 91,
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]+)?Z$"
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "goal", "status", "outcomes", "assumptions", "approval", "updated_at"],
  "properties": {
    "schema_version": { "const": "opennori/contract-v1" },
    "task_id": { "$ref": "#/$defs/taskId" },
    "goal": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "approved"] },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "verification", "required"],
        "properties": {
          "id": { "type": "string", "pattern": "^outcome-[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "statement": { "type": "string", "minLength": 1 },
          "verification": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" }
        }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "approval": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["approver", "approved_at", "content_hash"],
          "properties": {
            "approver": { "type": "string", "minLength": 1 },
            "approved_at": { "$ref": "#/$defs/timestamp" },
            "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
            "host_confirmation_ref": { "type": "string", "minLength": 1 },
            "note": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "updated_at": { "$ref": "#/$defs/timestamp" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "approved" } }, "required": ["status"] },
      "then": { "properties": { "approval": { "type": "object" } } },
      "else": { "properties": { "approval": { "type": "null" } } }
    }
  ]
}
