{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opennori.dev/schemas/contract.schema.json",
  "title": "OpenNori Nori Contract",
  "type": "object",
  "required": ["protocol_version", "goal_id", "goal", "criteria"],
  "additionalProperties": true,
  "properties": {
    "protocol_version": { "const": "opennori/v1" },
    "goal_id": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "presentation": { "type": "object" },
    "acceptance_basis": { "type": "object" },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "user_story", "measurement", "threshold"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "layer": { "type": "string" },
          "user_story": { "type": "string", "minLength": 1 },
          "measurement": { "type": "string", "minLength": 1 },
          "threshold": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "risk": { "type": "string" }
        }
      }
    }
  }
}
