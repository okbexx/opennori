{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opennori.dev/schemas/evidence.schema.json",
  "title": "OpenNori Evidence Record",
  "$defs": {
    "taskId": {
      "type": "string",
      "maxLength": 91,
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]+)?Z$"
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "task_id", "outcome_id", "result", "implementation_revision", "summary", "sources", "recorded_at"],
  "properties": {
    "schema_version": { "const": "opennori/evidence-v1" },
    "id": { "type": "string", "minLength": 1 },
    "task_id": { "$ref": "#/$defs/taskId" },
    "outcome_id": { "type": "string", "pattern": "^outcome-[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "result": { "enum": ["proven", "failed", "blocked", "waived"] },
    "implementation_revision": { "type": "integer", "minimum": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "command", "exit_code", "stdout", "stderr"],
            "properties": {
              "type": { "const": "command" },
              "command": { "type": "string", "minLength": 1, "maxLength": 4096 },
              "exit_code": { "type": "integer" },
              "stdout": { "type": "string", "maxLength": 262144 },
              "stderr": { "type": "string", "maxLength": 262144 },
              "argv": {
                "type": "array",
                "minItems": 1,
                "maxItems": 256,
                "items": { "type": "string", "maxLength": 4096 }
              },
              "cwd": { "type": "string", "minLength": 1, "maxLength": 4096 }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "path", "bytes", "sha256"],
            "properties": {
              "type": { "const": "artifact" },
              "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
              "bytes": { "type": "integer", "minimum": 0 },
              "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "actor", "host_confirmation_ref"],
            "properties": {
              "type": { "const": "human" },
              "actor": { "type": "string", "minLength": 1, "maxLength": 256 },
              "host_confirmation_ref": { "type": "string", "minLength": 1, "maxLength": 4096 }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "url", "summary"],
            "properties": {
              "type": { "const": "url" },
              "url": { "type": "string", "pattern": "^https://[^\\s]+$", "maxLength": 4096 },
              "summary": { "type": "string", "minLength": 1, "maxLength": 4096 }
            }
          }
        ]
      }
    },
    "recorded_at": { "$ref": "#/$defs/timestamp" }
  }
}
