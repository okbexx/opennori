{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opennori.dev/schemas/build-vs-buy.schema.json",
  "title": "OpenNori Build-vs-Buy Decision",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "created_at",
    "area",
    "need",
    "recommendation",
    "summary"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": "opennori/build-vs-buy-v1" },
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "area": { "type": "string", "minLength": 1 },
    "need": { "type": "string", "minLength": 1 },
    "recommendation": {
      "type": "string",
      "enum": ["reuse", "buy", "self-build"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "superseded"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "current_project": { "type": "string" },
    "standard_library": { "type": "string" },
    "official_sdk": { "type": "string" },
    "open_source": { "type": "string" },
    "self_build_reason": { "type": "string" },
    "superseded_by": { "type": "string" },
    "superseded_reason": { "type": "string" }
  }
}
