{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opennori.dev/schemas/coordination-binding.schema.json",
  "title": "OpenNori Host Coordination Binding",
  "$defs": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]+)?Z$"
    },
    "nullableTimestamp": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/timestamp" }]
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "implementation_revision",
    "platform",
    "parent_session_ref",
    "worker_ref",
    "role",
    "assignment",
    "outcome_ids",
    "paths",
    "started_at",
    "last_contact_at",
    "interrupted_at",
    "stopped_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "opennori/coordination-binding-v1" },
    "task_id": {
      "type": "string",
      "maxLength": 91,
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "implementation_revision": { "type": "integer", "minimum": 1 },
    "platform": { "const": "codex" },
    "parent_session_ref": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "worker_ref": { "type": "string", "minLength": 1, "maxLength": 256 },
    "role": { "type": "string", "minLength": 1, "maxLength": 80 },
    "assignment": {
      "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1, "maxLength": 1000 }]
    },
    "outcome_ids": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^outcome-[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80 }
    },
    "paths": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 4096 }
    },
    "started_at": { "$ref": "#/$defs/nullableTimestamp" },
    "last_contact_at": { "$ref": "#/$defs/nullableTimestamp" },
    "interrupted_at": { "$ref": "#/$defs/nullableTimestamp" },
    "stopped_at": { "$ref": "#/$defs/nullableTimestamp" },
    "updated_at": { "$ref": "#/$defs/timestamp" }
  }
}
