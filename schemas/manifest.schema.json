{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opennori.dev/schemas/manifest.schema.json",
  "title": "OpenNori Install Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "product_version", "state_schema_version", "platforms", "assets", "created_at", "updated_at"],
  "properties": {
    "schema_version": { "const": "opennori/install-manifest-v1" },
    "product_version": { "type": "string", "minLength": 1 },
    "state_schema_version": { "type": "integer", "minimum": 1 },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["codex", "claude"] }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["asset_id", "platform", "path", "scope", "policy", "last_written_hash"],
        "properties": {
          "asset_id": { "type": "string", "minLength": 1 },
          "platform": { "enum": ["core", "codex", "claude"] },
          "path": { "type": "string", "minLength": 1 },
          "scope": { "enum": ["file", "section"] },
          "policy": { "enum": ["managed", "seed"] },
          "last_written_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
