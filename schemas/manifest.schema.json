{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opennori.dev/schemas/manifest.schema.json",
  "title": "OpenNori Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "protocol_version",
    "opennori_version",
    "created_at",
    "updated_at",
    "capabilities",
    "managed_files",
    "active_goals",
    "current_goal",
    "plugin",
    "architecture"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": "opennori/manifest-v1" },
    "protocol_version": { "const": "opennori/v1" },
    "opennori_version": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "managed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "exists"],
        "additionalProperties": true,
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "exists": { "type": "boolean" }
        }
      }
    },
    "active_goals": { "type": "array" },
    "current_goal": {
      "anyOf": [
        { "type": "object" },
        { "type": "null" }
      ]
    },
    "draft_goals": { "type": "array" },
    "history_goals": { "type": "array" },
    "legacy_active_goals": { "type": "array" },
    "plugin": {
      "type": "object",
      "required": [
        "schema_version",
        "name",
        "version",
        "manifest_path",
        "marketplace_path",
        "marketplace_name",
        "marketplace_plugin_path",
        "skills_path",
        "packaged",
        "marketplace_packaged",
        "skill_count",
        "skills"
      ],
      "additionalProperties": true,
      "properties": {
        "schema_version": { "const": "opennori/plugin-v1" },
        "name": { "const": "opennori" },
        "version": { "type": "string" },
        "manifest_path": { "type": "string", "minLength": 1 },
        "marketplace_path": { "type": "string", "minLength": 1 },
        "marketplace_name": { "const": "opennori" },
        "marketplace_plugin_path": { "const": "./plugins/opennori" },
        "skills_path": { "type": "string", "minLength": 1 },
        "packaged": { "type": "boolean" },
        "marketplace_packaged": { "type": "boolean" },
        "skill_count": { "type": "integer", "minimum": 0 },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description", "path", "source"],
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "source": { "const": "package" }
            }
          }
        }
      }
    },
    "architecture": { "type": "object" }
  }
}
